# ============================================
# 成绩提醒系统 - 配置文件
# 复制此文件为 .env 并填入实际值
# ============================================

# --- 教务系统 ---
PORTAL_URL=https://zdbk.zju.edu.cn
STUDENT_ID=你的学号
PASSWORD=你的密码

# --- QQ 邮箱通知 ---
# SMTP 授权码获取方式：
#   QQ邮箱 → 设置 → 账户 → POP3/SMTP服务 → 开启 → 生成授权码
SENDER_EMAIL=你的QQ号@qq.com
SMTP_AUTH_CODE=你的QQ邮箱授权码
RECIPIENT_EMAIL=接收通知的邮箱

# --- 检查间隔（分钟）---
# 建议 15-60 分钟，太频繁可能被教务系统限制
CHECK_INTERVAL=15

# --- 数据目录（可选，Docker 部署时不用改）---
# DATA_DIR=./data
